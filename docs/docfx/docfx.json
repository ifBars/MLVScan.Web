{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../../../MLVScan.Core",
          "files": [
            "MLVScan.Core.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md",
          "index.md",
          "toc.yml"
        ]
      }
    ],
    "dest": "../../.generated/reference/core",
    "template": [
      "default",
      "modern",
      "templates/material"
    ],
    "globalMetadata": {
      "_appTitle": "MLVScan.Core Reference",
      "_appName": "MLVScan.Core Reference",
      "_appFooter": "Generated from XML documentation comments and public API metadata.",
      "_enableSearch": true,
      "_navbarTitle": "MLVScan.Core Reference"
    }
  }
}
